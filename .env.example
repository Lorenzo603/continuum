# =============================================================================
# Continuum — Database Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.

# Database type: 'sqlite' or 'postgres'
DB_TYPE=sqlite

# ---------------------------------------------------------------------------
# SQLite (used when DB_TYPE=sqlite)
# ---------------------------------------------------------------------------
SQLITE_PATH=./continuum.db

# ---------------------------------------------------------------------------
# PostgreSQL (used when DB_TYPE=postgres)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@localhost:5432/continuum

# Auth mode switch (build-time):
# - true  => Clerk auth enabled
# - false => legacy ACCESS_TOKEN header auth
NEXT_PUBLIC_ENABLE_CLERK_AUTH=true

# Legacy token auth settings (used when NEXT_PUBLIC_ENABLE_CLERK_AUTH=false)
ACCESS_TOKEN=<TOKEN_PLACEHOLDER>
ACCESS_TOKEN_CHECK_DISABLED=false
LEGACY_AUTH_USER_ID=legacy-user

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# MCP machine auth (choose one option)
# Option A: pre-minted Clerk bearer token
# CLERK_MCP_BEARER_TOKEN=
#
# Option B: client credentials flow
# CLERK_M2M_TOKEN_URL=
# CLERK_M2M_CLIENT_ID=
# CLERK_M2M_CLIENT_SECRET=
# CLERK_M2M_AUDIENCE=
# CLERK_M2M_SCOPE=